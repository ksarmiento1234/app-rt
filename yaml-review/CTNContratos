                Control: Label@2.5.1
                Properties:
                  Color: =RGBA(120, 53, 15, 1)
                  FillPortions: =1
                  Font: =Font.'Open Sans'
                  FontWeight: =FontWeight.Semibold
                  Size: =11
                  Text: |-
                    =With(
                        {
                            _porVencer: CountIf(
                                Contratos,
                                Estado = "Vigente" &&
                                !IsBlank(FechaFin) &&
                                DateDiff(Today(), FechaFin, TimeUnit.Days) <= _diasAlertaContrato &&
                                DateDiff(Today(), FechaFin, TimeUnit.Days) >= 0
                            ),
                            _proximo: CountIf(
                                Contratos,
                                Estado = "Vigente" &&
                                !IsBlank(FechaFin) &&
                                DateDiff(Today(), FechaFin, TimeUnit.Days) > _diasAlertaContrato &&
                                DateDiff(Today(), FechaFin, TimeUnit.Days) <= _diasAvisoContrato
                            )
                        },
                        If(
                            _porVencer > 0 && _proximo > 0,
                            "⚠  " & _porVencer & " contrato(s) vencen en menos de " & _diasAlertaContrato & " días  ·  " & _proximo & " vencen en menos de " & _diasAvisoContrato & " días",
                            If(
                                _porVencer > 0,
                                "🔴  " & _porVencer & " contrato(s) vencen en menos de " & _diasAlertaContrato & " días",
                                "🟡  " & _proximo & " contrato(s) vencen en menos de " & _diasAvisoContrato & " días"
                            )
                        )
                    )
