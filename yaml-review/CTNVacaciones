      - CTN_Vac_BannerAlertas:
          Control: GroupContainer@1.5.0
          Variant: AutoLayout
          Properties:
            BorderColor: =RGBA(180, 83, 9, 1)
            BorderThickness: =1
            DropShadow: =DropShadow.None
            Fill: =RGBA(255, 237, 213, 1)
            FillPortions: =0
            Height: =If(_hayAlertasVacaciones, 44, 0)
            LayoutAlignItems: =LayoutAlignItems.Center
            LayoutDirection: =LayoutDirection.Horizontal
            LayoutGap: =10
            LayoutMaxHeight: =
            LayoutMaxWidth: =
            PaddingLeft: =12
            PaddingRight: =12
            RadiusBottomLeft: =8
            RadiusBottomRight: =8
            RadiusTopLeft: =8
            RadiusTopRight: =8
            Visible: =_hayAlertasVacaciones
            Width: =Parent.Width
          Children:
            - Lbl_Vac_Banner:
                Control: Label@2.5.1
                Properties:
                  Color: =RGBA(120, 53, 15, 1)
                  FillPortions: =1
                  Font: =Font.'Open Sans'
                  FontWeight: =FontWeight.Semibold
                  Height: =44
                  Size: =11
                  Text: |-
                    =With(
                        {
                            _triple: CountIf(colAlertasVacaciones, EstadoAlerta = "TRIPLE_VACACIONAL"),
                            _urgente: CountIf(colAlertasVacaciones, EstadoAlerta = "URGENTE"),
                            _alerta: CountIf(colAlertasVacaciones, EstadoAlerta = "ALERTA")
                        },
                        "⚠  " &
                        If(_triple > 0, _triple & " en riesgo de triple vacacional  ·  ", "") &
                        If(_urgente > 0, _urgente & " urgente(s)  ·  ", "") &
                        If(_alerta > 0, _alerta & " próximo(s) a vencer", "")
                    )
                  Width: =Parent.Width - 130
            - CTN_Vac_BtnVerAlertas:
                Control: GroupContainer@1.5.0
                Variant: ManualLayout
                Properties:
                  AlignInContainer: =AlignInContainer.Center
                  BorderColor: =RGBA(180, 83, 9, 1)
                  BorderThickness: =1
                  DropShadow: =DropShadow.None
                  Fill: =RGBA(255, 255, 255, 1)
                  FillPortions: =0
                  Height: =28
                  RadiusBottomLeft: =6
                  RadiusBottomRight: =6
                  RadiusTopLeft: =6
                  RadiusTopRight: =6
                  Width: =100
                Children:
                  - Lbl_Vac_BtnVerAlertas:
                      Control: Label@2.5.1
                      Properties:
                        Align: =Align.Center
                        Color: =RGBA(120, 53, 15, 1)
                        Font: =Font.'Open Sans'
                        FontWeight: =FontWeight.Bold
                        Height: =28
                        Size: =10
                        Text: ="Ver alertas"
                        Width: =100
                  - Btn_Vac_VerAlertas:
                      Control: Classic/Button@2.2.0
                      Properties:
                        BorderStyle: =BorderStyle.None
                        Fill: =RGBA(0, 0, 0, 0)
                        Height: =Parent.Height
                        HoverFill: =varHoverFill
                        OnSelect: =Set(_tabVacacion, "Alertas")
                        PressedFill: =varPressedFill
