                  BorderColor: =RGBA(214, 221, 224, 1)
                  BorderStyle: =BorderStyle.Solid
                  BorderThickness: =1
                  Height: =34
                  InputTextPlaceholder: ="Estado..."
                  IsSearchable: =false
                  Items: |-
                    =Table(
                        {Estado: "Todos"},
                        {Estado: "Programada"},
                        {Estado: "Aprobada"},
                        {Estado: "Tomada"},
                        {Estado: "Cancelada"}
                    )
                  Width: =160
                Children:
                  - DDField_Vac_Estado_1:
                      Control: ComboBoxDataField@1.5.0
                      Variant: textualColumn
                      IsLocked: true
                      Properties:
                        FieldDisplayName: ="Estado"
                        FieldName: ="Estado"
                        FieldType: ="s"
                        Order: =1
