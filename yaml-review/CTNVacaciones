                              FontWeight: =FontWeight.Bold
                              Height: =34
                              Size: =10
                              Text: |-
                                ="🕐 Pendientes"
                              Width: =115
                        - Btn_Vac_TabPendientes:
                            Control: Classic/Button@2.2.0
                            Properties:
                              BorderStyle: =BorderStyle.None
                              Fill: =RGBA(0, 0, 0, 0)
                              Height: =Parent.Height
                              HoverFill: =varHoverFill
                              OnSelect: =Set(_tabVacacion, "Pendientes")
                              PressedFill: =varPressedFill
                              Text: =""
                              Width: =Parent.Width
                  - CTN_Vac_TabAlertas:
                      Control: GroupContainer@1.5.0
                      Variant: ManualLayout
                      Properties:
                        AlignInContainer: =AlignInContainer.Center
                        Fill: |-
                          =If(
                              _tabVacacion = "Alertas",
                              RGBA(180, 0, 0, 1),
                              RGBA(240, 240, 245, 1)
                          )
                        FillPortions: =0
                        Height: =34
                        RadiusBottomLeft: =0
                        RadiusBottomRight: =8
                        RadiusTopLeft: =0
                        RadiusTopRight: =8
                        Width: =90
                      Children:
                        - Lbl_Vac_TabAlertas:
                            Control: Label@2.5.1
                            Properties:
                              Align: =Align.Center
                              Color: |-
                                =If(
                                    _tabVacacion = "Alertas",
                                    Color.White,
                                    PrimaryTextColor
                                )
                              Font: =Font.'Open Sans'
                              FontWeight: =FontWeight.Bold
                              Height: =34
                              Size: =10
                              Text: |-
                                ="🔴 Alertas"
                              Width: =90
                        - Btn_Vac_TabAlertas:
                            Control: Classic/Button@2.2.0
                            Properties:
                              BorderStyle: =BorderStyle.None
                              Fill: =RGBA(0, 0, 0, 0)
                              Height: =Parent.Height
                              HoverFill: =varHoverFill
                              OnSelect: =Set(_tabVacacion, "Alertas")
                              PressedFill: =varPressedFill
                              Text: =""
                              Width: =Parent.Width
      - CTN_Vac_Hdr:
          Control: GroupContainer@1.5.0
          Variant: AutoLayout
          Properties:
            DropShadow: =DropShadow.None
            Fill: =RGBA(33, 41, 93, 0.06)
            FillPortions: =0
            Height: =32
            LayoutAlignItems: =LayoutAlignItems.Center
            LayoutDirection: =LayoutDirection.Horizontal
            LayoutMaxHeight: =
            LayoutMaxWidth: =
            PaddingLeft: =10
            PaddingRight: =10
            RadiusBottomLeft: =0
            RadiusBottomRight: =0
            RadiusTopLeft: =8
            RadiusTopRight: =8
            Width: =Parent.Width
          Children:
            - Lbl_VacHdr_Usuario:
                Control: Label@2.5.1
                Properties:
                  Color: =PrimaryTextColor
