                                      ="data:image/svg+xml;utf8, " & EncodeUrl(
                                          Substitute(
                                              LookUp(customIcons, IconName = "Check").IconData,
                                              "currentColor", "#15803D"
                                          )
                                      )
                                    Width: =18
                                    X: =5
                                    Y: =5
                              - Btn_Vac_Aprobar:
                                  Control: Classic/Button@2.2.0
