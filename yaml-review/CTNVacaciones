                        - Btn_Vac_TabTodos:
                            Control: Classic/Button@2.2.0
                            Properties:
                              BorderStyle: =BorderStyle.None
                              Fill: =RGBA(0, 0, 0, 0)
                              Height: =Parent.Height
                              HoverFill: =varHoverFill
                              OnSelect: =Set(_tabVacacion, "Todos")
