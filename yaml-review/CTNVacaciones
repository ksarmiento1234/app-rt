                  RadiusTopRight: =8
                Children:
                  - Img_Vac_Lupa:
                      Control: Image@2.2.3
                      Properties:
                        Height: =20
                        Image: |-
                          ="data:image/svg+xml;utf8, " & EncodeUrl(
                              Substitute(
                                  LookUp(customIcons, IconName = "Search").IconData,
                                  "currentColor", "#21295D"
                              )
                          )
                        Width: =20
                        X: =8
                        Y: =7
                  - TI_Vac_Buscar:
                      Control: Classic/TextInput@2.3.2
