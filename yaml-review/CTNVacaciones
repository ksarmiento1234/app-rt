            - Lbl_VacHdr_Inicio:
                Control: Label@2.5.1
                Properties:
                  Color: =PrimaryTextColor
                  Font: =Font.'Open Sans'
                  FontWeight: =FontWeight.Bold
                  Height: =32
                  Size: =10
                  Text: ="INICIO"
                  Width: =90
            - Lbl_VacHdr_Fin:
                Control: Label@2.5.1
                Properties:
                  Color: =PrimaryTextColor
                  Font: =Font.'Open Sans'
                  FontWeight: =FontWeight.Bold
                  Height: =32
                  Size: =10
                  Text: ="FIN"
                  Width: =90
            - Lbl_VacHdr_Dias:
                Control: Label@2.5.1
                Properties:
                  Align: =Align.Center
                  Color: =PrimaryTextColor
                  Font: =Font.'Open Sans'
                  FontWeight: =FontWeight.Bold
                  Height: =32
                  Size: =10
                  Text: ="DÍAS"
                  Width: =50
            - Lbl_VacHdr_Saldo:
                Control: Label@2.5.1
                Properties:
                  Align: =Align.Center
                  Color: =PrimaryTextColor
                  Font: =Font.'Open Sans'
                  FontWeight: =FontWeight.Bold
                  Height: =32
                  Size: =10
                  Text: ="SALDO"
                  Width: =60
            - Lbl_VacHdr_Estado:
                Control: Label@2.5.1
                Properties:
                  Align: =Align.Center
                  Color: =PrimaryTextColor
                  FillPortions: =1
                  Font: =Font.'Open Sans'
                  FontWeight: =FontWeight.Bold
                  Height: =32
                  Size: =10
                  Text: ="ESTADO"
                  Width: =100
            - Lbl_VacHdr_Acciones:
                Control: Label@2.5.1
                Properties:
                  Align: =Align.Center
                  Color: =PrimaryTextColor
                  Font: =Font.'Open Sans'
                  FontWeight: =FontWeight.Bold
                  Height: =32
                  Size: =10
                  Text: ="ACCIONES"
                  Width: =90
      - GalleryVacaciones:
          Control: Gallery@2.15.0
          Variant: Vertical
          Properties:
            BorderStyle: =BorderStyle.None
            Height: =Parent.Height - 230
            Items: |-
              =Sort(
                    Filter(
                        Vacaciones,
                        (
                            IsBlank(TI_Vac_Buscar.Text) ||
                            LookUp(MAUsuarios, UsuarioID = ThisRecord.UsuarioID).Nombre in TI_Vac_Buscar.Text
                        ) &&
                        (
                            DD_Vac_FiltroEstado.Selected.Estado = "Todos" ||
                            IsBlank(DD_Vac_FiltroEstado.Selected.Estado) ||
                            Estado = DD_Vac_FiltroEstado.Selected.Estado
                        ) &&
                        (
                            _tabVacacion = "Todos" ||
                            IsBlank(_tabVacacion) ||
                            (
                                _tabVacacion = "Pendientes" &&
                                (Estado = "Programada" || Estado = "Aprobada")
                            ) ||
                            (
                                _tabVacacion = "Alertas" &&
                                !IsBlank(
                                    LookUp(
                                        VacacionesSaldoLegal,
                                        UsuarioID = ThisRecord.UsuarioID &&
                                        (
                                            EstadoAlerta = "URGENTE" ||
                                            EstadoAlerta = "ALERTA" ||
                                            EstadoAlerta = "TRIPLE_VACACIONAL"
                                        )
                                    )
                                )
                            )
                        )
                    ),
                    FechaInicio,
                    SortOrder.Descending
                )
            TemplatePadding: =0
            TemplateSize: =52
            Width: =Parent.Width
          Children:
            - CTN_Vac_Row:
                Control: GroupContainer@1.5.0
                Variant: AutoLayout
                Properties:
                  BorderColor: =RGBA(0, 18, 107, 0.08)
                  DropShadow: =DropShadow.None
                  Fill: |-
                    =If(
                        Mod(ThisItem.VacacionID, 2) = 0,
                        RGBA(255, 255, 255, 1),
                        RGBA(248, 249, 255, 1)
                    )
                  Height: =50
                  LayoutAlignItems: =LayoutAlignItems.Center
                  LayoutDirection: =LayoutDirection.Horizontal
                  PaddingLeft: =10
                  PaddingRight: =10
                  Width: =Parent.Width
                Children:
                  - txt_Vac_Usuario:
                      Control: Text@0.0.51
                      Properties:
                        FillPortions: =2
                        Font: =Font.'Lato Light'
                        FontColor: =PrimaryTextColor
                        Height: =50
                        LayoutMaxHeight: =
                        LayoutMaxWidth: =
                        LayoutMinWidth: =180
                        Text: =LookUp(MAUsuarios, UsuarioID = ThisItem.UsuarioID).Nombre
                        VerticalAlign: =VerticalAlign.Middle
                        Weight: ='TextCanvas.Weight'.Semibold
                        Width: =180
                  - txt_Vac_Periodo:
                      Control: Text@0.0.51
                      Properties:
                        Font: =Font.'Lato Light'
                        FontColor: =ColorFade(PrimaryTextColor, 30%)
                        Height: =50
                        LayoutMaxHeight: =
                        LayoutMaxWidth: =
                        LayoutMinWidth: =70
                        Text: ="Año " & Text(ThisItem.PeriodoAnio)
                        VerticalAlign: =VerticalAlign.Middle
                        Weight: ='TextCanvas.Weight'.Regular
                        Width: =100
                  - txt_Vac_Inicio:
                      Control: Text@0.0.51
                      Properties:
                        Font: =Font.'Lato Light'
                        FontColor: =PrimaryTextColor
                        Height: =50
                        LayoutMaxHeight: =
                        LayoutMaxWidth: =
                        LayoutMinWidth: =90
                        Text: =Text(ThisItem.FechaInicio, "DD/MM/YY")
                        VerticalAlign: =VerticalAlign.Middle
                        Weight: ='TextCanvas.Weight'.Semibold
                        Width: =90
                  - txt_Vac_Fin:
                      Control: Text@0.0.51
                      Properties:
                        Font: =Font.'Lato Light'
                        FontColor: =PrimaryTextColor
                        Height: =50
                        LayoutMaxHeight: =
                        LayoutMaxWidth: =
                        LayoutMinWidth: =90
                        Text: =Text(ThisItem.FechaFin, "DD/MM/YY")
                        VerticalAlign: =VerticalAlign.Middle
                        Weight: ='TextCanvas.Weight'.Semibold
                        Width: =90
                  - txt_Vac_Dias:
                      Control: Text@0.0.51
                      Properties:
                        Align: ='TextCanvas.Align'.Center
                        Font: =Font.'Lato Light'
                        FontColor: =PrimaryTextColor
                        Height: =50
                        LayoutMaxHeight: =
                        LayoutMaxWidth: =
                        LayoutMinWidth: =50
                        Text: =Text(ThisItem.DiasTomados) & "d"
                        VerticalAlign: =VerticalAlign.Middle
                        Weight: ='TextCanvas.Weight'.Semibold
                        Width: =50
                  - txt_Vac_Saldo:
                      Control: Text@0.0.51
                      Properties:
                        Align: ='TextCanvas.Align'.Center
                        Font: =Font.'Lato Light'
                        FontColor: |-
                          =With(
                              {
                                  _saldo: LookUp(VacacionesSaldoLegal, UsuarioID = ThisItem.UsuarioID).TotalDiasDisponibles
                              },
                              If(
                                  _saldo <= 0, RGBA(180, 0, 0, 1),
                                  If(_saldo <= 10, RGBA(180, 120, 0, 1), RGBA(34, 139, 34, 1))
                              )
                          )
                        Height: =50
                        LayoutMaxHeight: =
                        LayoutMaxWidth: =
                        LayoutMinWidth: =60
                        Text: |-
                          =With(
                              {
                                  _saldo: LookUp(VacacionesSaldoLegal, UsuarioID = ThisItem.UsuarioID).TotalDiasDisponibles
                              },
                              Text(_saldo) & "d"
                          )
                        VerticalAlign: =VerticalAlign.Middle
                        Weight: ='TextCanvas.Weight'.Semibold
                        Width: =60
                  - CTN_Vac_Badge:
                      Control: GroupContainer@1.5.0
                      Variant: ManualLayout
                      Properties:
                        AlignInContainer: =AlignInContainer.Center
                        DropShadow: =DropShadow.None
                        Fill: |-
                          =Switch(
                              ThisItem.Estado,
                              "Programada", RGBA(219, 234, 254, 1),
                              "Aprobada",   RGBA(220, 252, 231, 1),
                              "Tomada",     RGBA(237, 233, 254, 1),
                              "Cancelada",  RGBA(243, 244, 246, 1),
                              RGBA(243, 244, 246, 1)
                          )
                        Height: =26
                        RadiusBottomLeft: =13
                        RadiusBottomRight: =13
                        RadiusTopLeft: =13
                        RadiusTopRight: =13
                        Width: =90
                      Children:
                        - Lbl_Vac_Badge:
                            Control: Label@2.5.1
                            Properties:
                              Align: =Align.Center
                              Color: |-
                                =Switch(
                                    ThisItem.Estado,
                                    "Programada", RGBA(29, 78, 216, 1),
                                    "Aprobada",   RGBA(21, 128, 61, 1),
                                    "Tomada",     RGBA(109, 40, 217, 1),
                                    "Cancelada",  RGBA(107, 114, 128, 1),
                                    PrimaryTextColor
                                )
                              Font: =Font.'Open Sans'
                              FontWeight: =FontWeight.Bold
                              Height: =26
                              Size: =10
                              Text: |-
                                =Switch(
                                    ThisItem.Estado,
                                    "Programada", "🕐 Programada",
                                    "Aprobada",   "✅ Aprobada",
                                    "Tomada",     "🏖️ Tomada",
                                    "Cancelada",  "❌ Cancelada",
                                    ThisItem.Estado
                                )
                              Width: =90
                  - CTN_Vac_Acciones:
                      Control: GroupContainer@1.5.0
                      Variant: AutoLayout
                      Properties:
                        AlignInContainer: =AlignInContainer.Center
                        DropShadow: =DropShadow.None
                        FillPortions: =0
                        Height: =34
                        LayoutAlignItems: =LayoutAlignItems.Center
                        LayoutDirection: =LayoutDirection.Horizontal
                        LayoutGap: =6
                        LayoutMaxHeight: =
                        LayoutMaxWidth: =
                        Width: =90
                      Children:
                        - CTN_Vac_BtnAprobar:
                            Control: GroupContainer@1.5.0
                            Variant: ManualLayout
                            Properties:
                              AlignInContainer: =AlignInContainer.Center
                              DropShadow: =DropShadow.None
                              Fill: =RGBA(220, 252, 231, 1)
                              FillPortions: =0
